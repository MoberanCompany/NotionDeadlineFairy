<Window x:Class="NotionDeadlineFairy.Views.FilterEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="텍스트 필터 편집" Width="500" Height="200"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="확인" Width="80" Margin="0,0,8,0" Click="OkButton_Click"/>
            <Button Content="취소" Width="80" Click="CancelButton_Click"/>
        </StackPanel>
        <StackPanel>
            <TextBlock Text="필터 조건 입력" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Text="예) 강정수 AND (완료 OR 진행중)" Foreground="Gray" Margin="0,0,0,8"/>
            <TextBlock Text="예) NOT 완료 AND 강정수" Foreground="Gray" Margin="0,0,0,8"/>
            <TextBox x:Name="FilterTextBox" Height="40" FontSize="14"
                     VerticalContentAlignment="Center" Padding="4"/>
        </StackPanel>
    </DockPanel>
</Window>