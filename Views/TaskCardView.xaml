<UserControl
    x:Class="NotionDeadlineFairy.Views.TaskCardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignWidth="300"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <DropShadowEffect
            x:Key="CardShadow"
            BlurRadius="6"
            Opacity="0.1"
            ShadowDepth="1"
            Color="Black" />
    </UserControl.Resources>

    <Border
        x:Name="MainBorder"
        Margin="4,2"
        Padding="10,8"
        Background="{Binding CardBackground}"
        BorderThickness="1"
        CornerRadius="8"
        Effect="{StaticResource CardShadow}">

        <Border.BorderBrush>
            <SolidColorBrush Color="#20000000" />
        </Border.BorderBrush>

        <StackPanel>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Margin="0,4,2,0"
                    HorizontalAlignment="Left"
                    FontFamily="{Binding DataContext.DefaultFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                    FontSize="{Binding DataContext.DatabaseTitleFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                    Foreground="{Binding DataContext.ForegroundBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                    Opacity="0.5"
                    Text="{Binding DatabaseTitle}" />

                <TextBlock
                    Grid.Row="1"
                    Margin="0,0,0,4"
                    FontFamily="{Binding DataContext.DefaultFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                    FontSize="{Binding DataContext.DefaultFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                    FontWeight="Bold"
                    Foreground="{Binding DataContext.ForegroundBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                    Text="{Binding Title}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap" />

                <Border
                    Grid.Row="2"
                    Padding="6,4"
                    Background="#15000000"
                    CornerRadius="4"
                    Visibility="{Binding HasDeadline, Converter={StaticResource BoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="{Binding TimerColor}"
                            Text="⏰" />
                        <TextBlock
                            x:Name="TimerDisplay"
                            FontFamily="{Binding DataContext.DefaultFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                            FontSize="{Binding TimerFontSize}"
                            FontWeight="ExtraBold"
                            Foreground="{Binding TimerColor}"
                            Text="{Binding RemainingTimeText}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border
                x:Name="DetailPanel"
                Margin="0,10,0,0"
                Padding="0,8,0,0"
                BorderBrush="#20000000"
                BorderThickness="0,1,0,0">
                <ItemsControl ItemsSource="{Binding Values}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    FontFamily="{Binding DataContext.DefaultFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                    FontSize="{Binding DataContext.DetailFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                    FontWeight="SemiBold"
                                    Foreground="{Binding DataContext.ForegroundBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Opacity="0.6"
                                    Text="{Binding Key}" />
                                <TextBlock
                                    Grid.Column="1"
                                    FontFamily="{Binding DataContext.DefaultFontFamily, RelativeSource={RelativeSource AncestorType=Window}}"
                                    FontSize="{Binding DataContext.DetailFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Foreground="{Binding DataContext.ForegroundBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Text="{Binding Value.Value}"
                                    TextAlignment="Right"
                                    TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
