<UserControl
    x:Class="NotionDeadlineFairy.Views.NotionDatabaseSettingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:NotionDeadlineFairy.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:NotionDeadlineFairy.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewModels:NotionDatabaseSettingViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <DataGrid Grid.Row="0" ItemsSource="{Binding SettingList}">
            <DataGridTextColumn Binding="{Binding Name}" />

            <DataGridTextColumn Binding="{Binding ApiKey}" />

            <DataGridTextColumn Binding="{Binding DatabaseUrl}" />

            <DataGridTextColumn Binding="{Binding IsConnected}" />

            <DataGridTextColumn Binding="{Binding ShowingProperties}" />

            <DataGridTextColumn Binding="{Binding EndDatePropertyName}" />

            <DataGridTextColumn Binding="{Binding ResultMessage}" />
        </DataGrid>

        <Button Grid.Row="1" Content="Save" />
    </Grid>
</UserControl>
