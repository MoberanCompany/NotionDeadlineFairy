<Window
    x:Class="NotionDeadlineFairy.Views.NotionDatabaseSettingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:NotionDeadlineFairy.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:NotionDeadlineFairy.ViewModels"
    Width="800"
    Height="400"
    MinWidth="600"
    MinHeight="300"
    d:DataContext="{d:DesignInstance Type=viewModels:NotionDatabaseSettingViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <DataGrid
            Grid.Row="0"
            AutoGenerateColumns="False"
            ItemsSource="{Binding SettingList}">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding Name}"
                    Header="Name" />

                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding ApiKey}"
                    Header="Notion API Key" />

                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding DatabaseUrl}"
                    Header="Notion Database URL" />

                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding EndDatePropertyName}"
                    Header="End Date Property Name" />

                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding ShowingProperties}"
                    Header="Showing Properties (CSV)" />

                <DataGridTextColumn
                    Width="50"
                    Binding="{Binding IsConnected}"
                    Header="IsConnected"
                    IsReadOnly="True" />

                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding ResultMessage}"
                    Header="Result"
                    IsReadOnly="True" />

                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button
                                Command="{Binding DataContext.TestFetchCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                CommandParameter="{Binding}"
                                Content="Test" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <Button
            Grid.Row="1"
            Command="{Binding SaveCommand}"
            Content="Save" />
    </Grid>
</Window>
